{
  "name": "hospital-api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext js,json --signal SIGTERM server.js",
    "start": "node server.js",
    "seed:roles": "node src/scripts/seedRoles.js"
  },
  "dependencies": {
    "bcrypt": "5.1.1",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.2",
    "module-alias": "2.2.3",
    "mongoose": "8.6.0",
    "morgan": "1.10.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "nodemon": "3.1.0"
  },
  "_moduleAliases": {
    "src": "src",
    "middlewares": "src/middlewares",
    "modules": "src/modules",
    "db": "src/db",
    "utils": "src/utils"
  }
}
